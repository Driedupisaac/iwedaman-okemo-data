    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import json\n",
        "from urllib.request import urlopen\n",
        "import plotly.express as px\n",
        "\n",
        "with urlopen('https://raw.githubusercontent.com/plotly/datasets/master/geojson-counties-fips.json') as f:\n",
        "    counties = json.load(f)\n",
        "\n",
        "counties_names = {f['id']: f['properties']['NAME'] for f in counties['features']}\n",
        "\n",
        "counts_per_county['county_name'] = counts_per_county['counties'].map(counties_names)\n",
        "\n",
        "county_walk_index = (\n",
        "    cleaned.groupby('counties')['NatWalkInd']\n",
        "    .median()\n",
        "    .reset_index(name='median_walk')\n",
        ")\n",
        "#adding \"county\" to each county's name \n",
        "county_walk_index['county_name'] = county_walk_index['counties'].map(counties_names) + \" County\"\n",
        "\n",
        "all_fips = pd.DataFrame({'counties': [f['id'] for f in counties['features']]})\n",
        "\n",
        "# attach our walkability where we have it; counties with none become NaN\n",
        "county_walk_full = all_fips.merge(\n",
        "    county_walk_index[['counties', 'median_walk']],\n",
        "    on='counties',\n",
        "    how='left',\n",
        ")\n",
        "\n",
        "#filling all instances of data = na to 0\n",
        "county_walk_full['median_walk'] = county_walk_full['median_walk'].fillna(0)\n",
        "\n",
        "#adding the names to all counties\n",
        "county_walk_full['county_name'] = county_walk_full['counties'].map(counties_names)\n",
        "\n",
        "\n",
        "fig = px.choropleth(\n",
        "    county_walk_full,\n",
        "    geojson=counties,\n",
        "    locations='counties',\n",
        "    color='median_walk',\n",
        "    color_continuous_scale=[\n",
        "        [0.0, '#ececec'],\n",
        "        [0.4, '#9ecae1'],\n",
        "        [1.0, '#08306b'],\n",
        "    ],\n",
        "    range_color=(1, 16),\n",
        "    scope='usa',\n",
        "    hover_name='county_name',\n",
        "    hover_data={'counties': True, 'median_walk': ':.1f'},\n",
        "    labels={'median_walk': 'Walkability'},\n",
        ")\n",
        "fig.update_geos(showland=True, landcolor='#f7f7f7')\n",
        "fig.update_layout(margin={'r': 0, 't': 0, 'l': 0, 'b': 0})\n",
        "fig.show()\n"
      ],
      "id": "7b5a4e5c",
