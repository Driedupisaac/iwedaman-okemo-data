    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Using shapely to blow the ocunties up proportionally"
      ],
      "id": "cd794d8b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import copy\n",
        "from shapely.geometry import shape, mapping\n",
        "from shapely.affinity import scale\n",
        "\n",
        "# FIPS -> walkability score, for quick lookup\n",
        "walk_lookup = dict(zip(county_walk_full['counties'], county_walk_full['median_walk']))\n",
        "max_score = county_walk_full['median_walk'].max()\n",
        "\n",
        "# turn a walkability score into a size multiplier\n",
        "def size_factor(score):\n",
        "    if score <= 0:\n",
        "        return 0.25                              # no-data counties shrink away\n",
        "    return .6 + (score / max_score) ** 4 * 10  # walkable ones balloon\n",
        "\n",
        "# build a NEW geojson with each county scaled around its own centroid\n",
        "blown_up = copy.deepcopy(counties)               # copy so the original stays intact\n",
        "for feature in blown_up['features']:\n",
        "    fips = feature['id']\n",
        "    factor = size_factor(walk_lookup.get(fips, 0))\n",
        "    geom = shape(feature['geometry'])            # geojson -> shapely shape\n",
        "    scaled = scale(geom, xfact=factor, yfact=factor, origin='centroid')\n",
        "    feature['geometry'] = mapping(scaled)        # shapely \n",
        "\n",
        "\n",
        "fig = px.choropleth(\n",
        "    county_walk_full,\n",
        "    geojson=blown_up,          # <- the only change: distorted geometry\n",
        "    locations='counties',\n",
        "    color='median_walk',\n",
        "    color_continuous_scale='Viridis',\n",
        "    range_color=(0, 16),\n",
        "    scope='usa',\n",
        "    hover_name='county_name',\n",
        "    hover_data={'counties': True, 'median_walk': ':.1f'},\n",
        "    labels={'median_walk': 'Walkability'},\n",
        ")\n",
        "fig.update_geos(showland=True, landcolor='#f7f7f7')\n",
        "fig.update_layout(margin={'r': 0, 't': 0, 'l': 0, 'b': 0})\n",
        "fig.show()\n"
      ],
      "id": "5971b74e",
      "execution_count": null,
      "outputs": []
