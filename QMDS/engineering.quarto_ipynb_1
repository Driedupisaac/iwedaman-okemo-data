    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "#we need to ake a copy! so first, we copy the raw on which to make edits, and then we must start by converting the geoid columns, which are described as numbers, to float 64's, and move on frmo there"
      ],
      "id": "4cc381df"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "cleaned = data.copy()\n",
        "cleaned[\"GEOID10\"].describe()\n",
        "\n",
        "#first, we change the type of float64 to int64 to pare the trailing 0\n",
        "cleaned['GEOID20'] = cleaned['GEOID20'].astype('int64')\n",
        "#now changing it to string to make it\n",
        "cleaned[\"GEOID20\"] = cleaned['GEOID20'].astype(str)\n",
        "#by making a number in the first place, we accidentally took away a potential leading 0, and now we add a leading 0, so the states 0-9 arent left out\n",
        "cleaned[\"GEOID20\"] = cleaned['GEOID20'].str.zfill(12)\n",
        "\n",
        "cleaned[\"GEOID20\"].describe()\n",
        "\n",
        "#now, we must parse the counties, which are the first five codes of the dataset\n",
        "cleaned['counties'] = cleaned['GEOID20'].str[:5]\n",
        "\n",
        "counts_per_county = (\n",
        "    cleaned\n",
        "    .groupby('counties')\n",
        "    .size()\n",
        "    .reset_index(name='n_blockgroups')\n",
        ")\n",
        "counts_per_county.head()\n"
